{
  "expo": {
    "name": "Serphint",
    "slug": "Serphint",
    "scheme": "Serphint",
    "version": "1.0.0",

    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/serphint_icon_red.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/serphint_icon_red.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eanuichi.Serphint",
      "icon": "./assets/serphint_icon_red.png",
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/serphint_icon_red.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.eanuichi.Serphint"
    },
    "web": {
      "favicon": "./assets/serphint_icon_red.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) needs access to your Camera.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "$(PRODUCT_NAME) needs access to your Microphone."
        }
      ],

      [
        "react-native-video",
        {
          "enableNotificationControls": true,
          "androidExtensions": {
            "useExoplayerRtsp": false,
            "useExoplayerSmoothStreaming": false,
            "useExoplayerHls": false,
            "useExoplayerDash": false
          }
        }
      ],

      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."


        }
      ]
    ]
  }
}
